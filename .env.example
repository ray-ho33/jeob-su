# 법제처 Open API 키: 결정문 다운로드에 필요합니다.
LAW_OC=
# KOREAN_LAW_API_KEY=

# Gemini API 키: 시맨틱 색인 생성과 검색에 필요합니다.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# HTTP MCP 서버 설정
PORT=3000
HOST=0.0.0.0

# 선택: 공개 HTTP MCP 서버를 간단히 보호할 때 사용합니다.
# MCP_ACCESS_TOKEN=

# 선택: 브라우저 Origin 허용 목록을 쉼표로 추가합니다.
# 기본 허용: https://claude.ai, https://www.claude.ai, localhost 계열
# MCP_ALLOWED_ORIGINS=https://your-domain.example

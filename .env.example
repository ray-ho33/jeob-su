# Copy to the project root as .env and fill in the values you need.
# Do not commit API keys, tokens, or secrets.

# Korean law Open API key, used by download_acr_decisions.
LAW_OC=
# KOREAN_LAW_API_KEY=

# Google AI Studio key, used by build_semantic_index and search_similar_decisions.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# HTTP MCP server settings.
PORT=3000
HOST=0.0.0.0

# Optional: simple protection for a public HTTP MCP server.
# MCP_ACCESS_TOKEN=

# Optional: comma-separated list of additional browser Origins.
# Defaults allow https://claude.ai, https://www.claude.ai, and localhost.
# MCP_ALLOWED_ORIGINS=https://your-domain.example

# Optional: expose download/index tools over HTTP (off by default; stdio always has them).
# MCP_ENABLE_MUTATING_TOOLS=1

# Optional: per-IP request limit per minute for POST /mcp (default 60, 0 disables).
# MCP_RATE_LIMIT=60
